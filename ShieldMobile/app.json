{
  "expo": {
    "name": "ShieldMobile",
    "slug": "shield-mobile",
    "scheme": "shieldmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0f4ff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shield.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f0f4ff"
      },
      "package": "com.shield.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "SHIELD a besoin d'accéder à la caméra pour photographier les documents à vérifier."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SHIELD a besoin d'accéder à vos photos pour vérifier un document."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4127ad6c-7cbf-44bf-85b5-ed5fe6693a0d"
      }
    }
  }
}
