{
  "expo": {
    "name": "ShieldMobile",
    "slug": "shield-mobile",
    "scheme": "shieldmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0f4ff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shield.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f0f4ff"
      },
      "package": "com.shield.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "SHIELD a besoin d'accéder à la caméra pour photographier les documents à vérifier."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SHIELD a besoin d'accéder à vos photos pour vérifier un document."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.VOTRE_IOS_CLIENT_ID_NUMERIQUE"
        }
      ]
    ]
  }
}