# ──────────────────────────────────────────────
# SHIELD Backend — fichier .env
# Copiez ce fichier dans backend/.env et
# remplissez les valeurs avant de lancer l'API.
# ──────────────────────────────────────────────

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=signature_communiques_officiels
DB_USER=magistral
DB_PASSWORD=votre_mot_de_passe_postgres

# JWT
JWT_SECRET_KEY=changez_cette_cle_en_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Bcrypt
BCRYPT_ROUNDS=12

# OTP / 2FA
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6

# Clé Fernet pour chiffrer les clés privées RSA
# Générez avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=votre_cle_fernet_generee_ici
